            tensor<fp16, [1, 1, 256, 32, 18]> update_gate_cast_fp16 = sigmoid(x = var_415_cast_fp16)[name = string("update_gate_cast_fp16")];
            tensor<int32, [5]> var_422_begin_0 = const()[name = string("op_422_begin_0"), val = tensor<int32, [5]>([0, 0, 512, 0, 0])];
            tensor<int32, [5]> var_422_end_0 = const()[name = string("op_422_end_0"), val = tensor<int32, [5]>([1, 1, 768, 32, 18])];
            tensor<bool, [5]> var_422_end_mask_0 = const()[name = string("op_422_end_mask_0"), val = tensor<bool, [5]>([true, true, true, true, true])];
