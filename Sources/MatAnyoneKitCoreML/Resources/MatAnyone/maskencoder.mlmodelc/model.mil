            tensor<fp16, [1, 1, 256, 32, 18]> g_15_cast_fp16 = reshape(shape = var_379, x = g_13_cast_fp16)[name = string("g_15_cast_fp16")];
            bool g_19_interleave_0 = const()[name = string("g_19_interleave_0"), val = bool(false)];
            tensor<fp16, [1, 1, 512, 32, 18]> g_19_cast_fp16 = concat(axis = var_19, interleave = g_19_interleave_0, values = (g_15_cast_fp16, sensory))[name = string("g_19_cast_fp16")];
            tensor<int32, [4]> concat_5 = const()[name = string("concat_5"), val = tensor<int32, [4]>([1, 512, 32, 18])];
            tensor<fp16, [1, 512, 32, 18]> input_cast_fp16 = reshape(shape = concat_5, x = g_19_cast_fp16)[name = string("input_cast_fp16")];
            string g_pad_type_0 = const()[name = string("g_pad_type_0"), val = string("custom")];
            tensor<int32, [4]> g_pad_0 = const()[name = string("g_pad_0"), val = tensor<int32, [4]>([1, 1, 1, 1])];
            tensor<int32, [2]> g_strides_0 = const()[name = string("g_strides_0"), val = tensor<int32, [2]>([1, 1])];
            tensor<int32, [2]> g_dilations_0 = const()[name = string("g_dilations_0"), val = tensor<int32, [2]>([1, 1])];
            int32 g_groups_0 = const()[name = string("g_groups_0"), val = int32(1)];
            tensor<fp16, [768, 512, 3, 3]> m_mask_encoder_sensory_update_transform_weight_to_fp16 = const()[name = string("m_mask_encoder_sensory_update_transform_weight_to_fp16"), val = tensor<fp16, [768, 512, 3, 3]>(BLOBFILE(path = string("@model_path/weights/weight.bin"), offset = uint64(10553920)))];
            tensor<fp16, [768]> m_mask_encoder_sensory_update_transform_bias_to_fp16 = const()[name = string("m_mask_encoder_sensory_update_transform_bias_to_fp16"), val = tensor<fp16, [768]>(BLOBFILE(path = string("@model_path/weights/weight.bin"), offset = uint64(17631872)))];
            tensor<fp16, [1, 768, 32, 18]> g_cast_fp16 = conv(bias = m_mask_encoder_sensory_update_transform_bias_to_fp16, dilations = g_dilations_0, groups = g_groups_0, pad = g_pad_0, pad_type = g_pad_type_0, strides = g_strides_0, weight = m_mask_encoder_sensory_update_transform_weight_to_fp16, x = input_cast_fp16)[name = string("g_cast_fp16")];
            tensor<int32, [5]> var_399 = const()[name = string("op_399"), val = tensor<int32, [5]>([1, 1, 768, 32, 18])];
            tensor<fp16, [1, 1, 768, 32, 18]> values_cast_fp16 = reshape(shape = var_399, x = g_cast_fp16)[name = string("values_cast_fp16")];
            tensor<int32, [5]> var_408_begin_0 = const()[name = string("op_408_begin_0"), val = tensor<int32, [5]>([0, 0, 0, 0, 0])];
            tensor<int32, [5]> var_408_end_0 = const()[name = string("op_408_end_0"), val = tensor<int32, [5]>([1, 1, 256, 32, 18])];
            tensor<bool, [5]> var_408_end_mask_0 = const()[name = string("op_408_end_mask_0"), val = tensor<bool, [5]>([true, true, false, true, true])];
            tensor<fp16, [1, 1, 256, 32, 18]> var_408_cast_fp16 = slice_by_index(begin = var_408_begin_0, end = var_408_end_0, end_mask = var_408_end_mask_0, x = values_cast_fp16)[name = string("op_408_cast_fp16")];
            tensor<fp16, [1, 1, 256, 32, 18]> forget_gate_cast_fp16 = sigmoid(x = var_408_cast_fp16)[name = string("forget_gate_cast_fp16")];
            tensor<int32, [5]> var_415_begin_0 = const()[name = string("op_415_begin_0"), val = tensor<int32, [5]>([0, 0, 256, 0, 0])];
            tensor<int32, [5]> var_415_end_0 = const()[name = string("op_415_end_0"), val = tensor<int32, [5]>([1, 1, 512, 32, 18])];
