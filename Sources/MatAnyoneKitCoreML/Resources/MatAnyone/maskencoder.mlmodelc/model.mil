            tensor<fp16, [1, 1, 256, 32, 18]> var_425_cast_fp16 = sub(x = var_16_promoted_to_fp16, y = update_gate_cast_fp16)[name = string("op_425_cast_fp16")];
            tensor<fp16, [1, 1, 256, 32, 18]> var_426_cast_fp16 = mul(x = var_424_cast_fp16, y = var_425_cast_fp16)[name = string("op_426_cast_fp16")];
            tensor<fp16, [1, 1, 256, 32, 18]> var_427_cast_fp16 = mul(x = update_gate_cast_fp16, y = new_value_cast_fp16)[name = string("op_427_cast_fp16")];
            tensor<fp16, [1, 1, 256, 32, 18]> new_sensory = add(x = var_426_cast_fp16, y = var_427_cast_fp16)[name = string("op_428_cast_fp16")];
            bool var_433_interleave_0 = const()[name = string("op_433_interleave_0"), val = bool(false)];
            tensor<fp16, [1, 1, 256, 32, 18]> mask_value = concat(axis = var_16, interleave = var_433_interleave_0, values = g_15_cast_fp16)[name = string("op_433_cast_fp16")];
        } -> (mask_value, new_sensory);
}